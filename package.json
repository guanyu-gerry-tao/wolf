{
  "name": "wolf",
  "version": "0.1.0",
  "description": "AI-powered job hunting CLI and MCP server",
  "type": "module",
  "bin": {
    "wolf": "./dist/cli/index.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && tsup",
    "build:dev": "npm run typecheck && WOLF_BUILD_MODE=dev tsup",
    "dev": "tsup --watch",
    "wolf": "node dist/cli/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.10.1",
    "better-sqlite3": "^12.9.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "openai": "^6.34.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "smol-toml": "^1.6.0",
    "update-notifier": "^7.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/update-notifier": "^6.0.8",
    "pdf-lib": "^1.17.1",
    "pino-test": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
