# Dependencies
node_modules/

# Build output
dist/
build/
# Stable npm publish staging directory (created by scripts/publish-stable.sh)
dist-package/

# Environment & secrets
.env
.env.local
.env.*.local

# Wolf config & data (user-specific)
wolf.toml
wolf.toml.backup*
wolf.db
*.sqlite
*.sqlite3

# Tailored resumes & outputs (generated files)
output/*
tailored/*
*.tailored.md

# Playwright
playwright-report/*
test-results/*
screenshots/*

# Local test run reports and captured artifacts. Keep only .gitkeep.
test/runs/**

# Logs
logs/*
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/settings.json
.idea/
*.code-workspace

# TypeScript
*.tsbuildinfo

# Claude Code memory — personal config + worktrees stay local;
# project-shared agent presets are committed. Note: `.claude/*` instead of
# `.claude/` because gitignore can't re-include a child of a fully-ignored
# directory (the negation patterns only work when the parent is open).
.claude/*
!.claude/agents/
.superpowers/

# data files
data/*

# Local resume samples for parser development (never commit)
samples/*

# Implementation plans (personal working docs, not shared)
docs/plans/*

# Visual review harness outputs (only baseline/ snapshots are committed)
extension/test/visual/snapshots/current/
extension/test/visual/snapshots/diffs/
extension/test/visual/report.md

# Always keep .gitkeep files (must be last)
!**/.gitkeep
